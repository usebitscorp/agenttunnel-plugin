#!/usr/bin/env bash
# Poll for new messages in an AgentTunnel conversation
# Usage: poll <secret> [--timeout <seconds>] [--interval <seconds>]

set -euo pipefail

SECRET=""
TIMEOUT=240  # 4 minutes default
INTERVAL=20  # 20 seconds default

# Parse args
while [[ $# -gt 0 ]]; do
  case $1 in
    --timeout)
      TIMEOUT="$2"
      shift 2
      ;;
    --interval)
      INTERVAL="$2"
      shift 2
      ;;
    --*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      if [[ -z "$SECRET" ]]; then
        SECRET="$1"
      else
        echo "Unexpected argument: $1" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$SECRET" ]]; then
  echo "Usage: poll <secret> [--timeout <seconds>] [--interval <seconds>]" >&2
  exit 1
fi

# Get current message count to know what "after" index to use
CURRENT=$(agt history --secret "$SECRET" --limit 1000 2>/dev/null || echo "")
if [[ -z "$CURRENT" ]]; then
  LAST_INDEX=0
else
  # Count messages - each message starts with a line like "[0] agent-name (timestamp):"
  LAST_INDEX=$(echo "$CURRENT" | grep -c '^\[' || echo "0")
fi

echo "Polling for new messages (after index $LAST_INDEX)..."
echo "Timeout: ${TIMEOUT}s, Interval: ${INTERVAL}s"
echo ""

START_TIME=$(date +%s)
while true; do
  ELAPSED=$(($(date +%s) - START_TIME))
  if [[ $ELAPSED -ge $TIMEOUT ]]; then
    echo "Timeout reached after ${TIMEOUT}s with no new messages."
    exit 0
  fi

  # Check for new messages
  NEW=$(agt history --secret "$SECRET" --after "$LAST_INDEX" 2>/dev/null || echo "")

  # "No messages yet." means no new messages - treat as empty
  if [[ -n "$NEW" && "$NEW" != "No messages yet." ]]; then
    echo "New messages received:"
    echo ""
    echo "$NEW"
    exit 0
  fi

  REMAINING=$((TIMEOUT - ELAPSED))
  echo "No new messages yet. Waiting ${INTERVAL}s... (${REMAINING}s remaining)"
  sleep "$INTERVAL"
done
